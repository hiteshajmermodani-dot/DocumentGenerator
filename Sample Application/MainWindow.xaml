<Window x:Class="Sample_Application.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Sample_Application"
        mc:Ignorable="d"
        Title="Report Generator" Height="620" Width="680"
        Background="#F0F4F8" WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Primary blue button style -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#1976D2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="16,10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1565C0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#0D47A1"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#90CAF9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary green button style -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#388E3C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="16,10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2E7D32"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1B5E20"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#A5D6A7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Small outline button -->
        <Style x:Key="OutlineButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#1976D2"/>
            <Setter Property="BorderBrush" Value="#1976D2"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5" Padding="12,6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E3F2FD"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#BBDEFB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Danger outline button -->
        <Style x:Key="DangerButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#D32F2F"/>
            <Setter Property="BorderBrush" Value="#D32F2F"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5" Padding="12,6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FFEBEE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Card border style -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.08" Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Section label -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#546E7A"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <!-- Checkbox style -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#37474F"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,16,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,20,24,24">

            <!-- Header Banner -->
            <Border CornerRadius="12" Margin="0,0,0,20">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1565C0" Offset="0"/>
                        <GradientStop Color="#0288D1" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel Margin="24,20,24,20">
                    <TextBlock Text="&#x1F4C4;  Report Generator"
                               FontSize="24" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Generate professional DOCX and PDF reports with table of contents, images, headers, footers and page numbers."
                               FontSize="12" Foreground="#B3E5FC" TextWrapping="Wrap" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <!-- Images Card -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="&#x1F5BC;  IMAGES" Style="{StaticResource SectionLabel}"/>
                    <DockPanel Margin="0,0,0,8">
                        <Button x:Name="btnAddImage" Content="+ Add Images" DockPanel.Dock="Right"
                                Style="{StaticResource OutlineButton}" Width="110"
                                Click="BtnAddImage_Click" Margin="8,0,0,0"/>
                        <Button x:Name="btnClearImages" Content="Clear All" DockPanel.Dock="Right"
                                Style="{StaticResource DangerButton}" Width="80"
                                Click="BtnClearImages_Click"/>
                        <TextBlock x:Name="txtImageCount" Text="No images selected"
                                   VerticalAlignment="Center" Foreground="#78909C" FontSize="13"/>
                    </DockPanel>
                    <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6">
                        <ListBox x:Name="lstImages" Height="65" BorderThickness="0"
                                 Background="Transparent" FontSize="12" Foreground="#455A64"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Options Card -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="&#x2699;  REPORT OPTIONS" Style="{StaticResource SectionLabel}"/>
                    <WrapPanel>
                        <CheckBox x:Name="chkHeader" Content="Header" IsChecked="True"/>
                        <CheckBox x:Name="chkFooter" Content="Footer" IsChecked="True"/>
                        <CheckBox x:Name="chkPageNumbers" Content="Page Numbers" IsChecked="True"/>
                        <CheckBox x:Name="chkNavigation" Content="Table of Contents" IsChecked="True"/>
                        <CheckBox x:Name="chkAutoSpacing" Content="Auto Spacing" IsChecked="True"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- Generate Buttons Card -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="&#x1F4E4;  GENERATE REPORT" Style="{StaticResource SectionLabel}"/>
                    <UniformGrid Columns="2" Rows="1">
                        <Button x:Name="btnGenerate" Content="&#x1F4C4;  Generate DOCX"
                                Style="{StaticResource PrimaryButton}"
                                Height="44" FontSize="14"
                                Click="BtnGenerate_Click" Margin="0,0,6,0"/>
                        <Button x:Name="btnGeneratePdf" Content="&#x1F4CB;  Generate PDF"
                                Style="{StaticResource SecondaryButton}"
                                Height="44" FontSize="14"
                                Click="BtnGeneratePdf_Click" Margin="6,0,0,0"/>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <!-- Status Card -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,0">
                <StackPanel>
                    <TextBlock Text="&#x1F4CB;  STATUS" Style="{StaticResource SectionLabel}"/>
                    <TextBlock x:Name="txtStatus" Text="Ready to generate your report."
                               Foreground="#2E7D32" FontSize="13" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Window>
